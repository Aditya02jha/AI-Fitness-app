
# .gitignore for a standard Maven/Java project
# Ignore Maven build output
target/

# Maven wrapper binary
.mvn/wrapper/maven-wrapper.jar

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# STS / Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/

# VS Code
.vscode/

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db
